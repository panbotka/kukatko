# Kukátko — example environment file for running the container on a VPS.
#
# Copy to `.env` (which is gitignored — NEVER commit a real one) and fill in the
# real values, then run e.g.:
#   docker run --env-file .env -p 8080:8080 \
#     -v kukatko-originals:/var/lib/kukatko/originals \
#     -v kukatko-cache:/var/lib/kukatko/cache \
#     ghcr.io/panbotka/kukatko:latest
#
# Every config key maps to an env var: the KUKATKO_ prefix, dots -> underscores
# (web.port -> KUKATKO_WEB_PORT). The env value always wins over any config file.
# The mapy.com key is the ONE exception: it is read from the unprefixed
# MAPY_API_KEY. The full key catalog lives in config.example.yaml and
# docs/OPERATIONS.md. All values below are placeholders — do NOT put real
# secrets in this example file.

# --- Database (REQUIRED) ----------------------------------------------------
# PostgreSQL DSN. The only mandatory setting; without it the server won't start.
KUKATKO_DATABASE_URL=postgres://kukatko:CHANGE_ME@db-host:5432/kukatko?sslmode=disable

# --- HTTP server ------------------------------------------------------------
# Listen host/port. The image EXPOSEs 8080; publish it with `-p`.
KUKATKO_WEB_HOST=0.0.0.0
KUKATKO_WEB_PORT=8080
# Signs session cookies. Set a long random value in production.
KUKATKO_WEB_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_STRING
# Enable when running behind a TLS-terminating reverse proxy (HTTPS-only cookies).
KUKATKO_WEB_SECURE_COOKIES=true
# Comma-separated CORS allowlist (leave empty for same-origin only).
# KUKATKO_WEB_ALLOWED_ORIGINS=https://photos.example.com

# --- Initial admin (first run only) -----------------------------------------
# Used once to bootstrap the admin account; remove afterwards.
KUKATKO_AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
KUKATKO_AUTH_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME

# --- Embedding sidecar ------------------------------------------------------
# URL of the external embedding service (image/face vectors). It may be offline:
# image_embed/face_detect jobs then wait in the queue; upload and browsing work.
KUKATKO_EMBEDDING_URL=http://embeddings-host:8000

# --- Storage of originals ---------------------------------------------------
# "fs" (default, local disk — mount the paths below as volumes) or "r2"
# (Cloudflare R2 for a host whose disk cannot hold the library).
KUKATKO_STORAGE_BACKEND=fs
KUKATKO_STORAGE_ORIGINALS_PATH=/var/lib/kukatko/originals
KUKATKO_STORAGE_CACHE_PATH=/var/lib/kukatko/cache
KUKATKO_STORAGE_TEMP_PATH=/var/lib/kukatko/tmp

# Cloudflare R2 — required only when KUKATKO_STORAGE_BACKEND=r2.
# KUKATKO_STORAGE_R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# KUKATKO_STORAGE_R2_REGION=auto
# KUKATKO_STORAGE_R2_BUCKET=kukatko-media
# KUKATKO_STORAGE_R2_ACCESS_KEY=CHANGE_ME
# KUKATKO_STORAGE_R2_SECRET_KEY=CHANGE_ME
# KUKATKO_STORAGE_R2_MEDIA_BASE_URL=https://kukatko-media.example.com
# KUKATKO_STORAGE_R2_URL_SIGNING_SECRET=CHANGE_ME
# KUKATKO_STORAGE_R2_URL_SIGNING_SECRET_PREVIOUS=
# KUKATKO_STORAGE_R2_URL_TTL=1h

# --- Backup (second, independent S3 bucket) ---------------------------------
# See docs/RESTORE.md. Leave empty to disable scheduled backups.
# KUKATKO_BACKUP_S3_ENDPOINT=https://s3.example.com
# KUKATKO_BACKUP_S3_REGION=us-east-1
# KUKATKO_BACKUP_S3_BUCKET=kukatko-backup
# KUKATKO_BACKUP_S3_ACCESS_KEY=CHANGE_ME
# KUKATKO_BACKUP_S3_SECRET_KEY=CHANGE_ME
# KUKATKO_BACKUP_S3_PATH_STYLE=false
# Cron / @daily etc.; empty disables the scheduler.
# KUKATKO_BACKUP_SCHEDULE=@daily
# KUKATKO_BACKUP_RETENTION=7

# --- Maps (mapy.com) --------------------------------------------------------
# The prefix-rule EXCEPTION: read from the unprefixed MAPY_API_KEY. Kept
# server-side (the tile/geocode proxies inject it); never exposed to the client.
MAPY_API_KEY=CHANGE_ME

# --- Read-only import sources (optional) ------------------------------------
# PhotoPrism stays primary during migration; its import is incremental.
# KUKATKO_IMPORT_PHOTOPRISM_BASE_URL=https://photoprism.example.com
# KUKATKO_IMPORT_PHOTOPRISM_TOKEN=CHANGE_ME
# One-off direct migration from the photo-sorter database.
# KUKATKO_IMPORT_PHOTOSORTER_DSN=postgres://reader:CHANGE_ME@ps-host:5432/photosorter?sslmode=disable

# --- Observability ----------------------------------------------------------
# Log level: debug|info|warn|error (default info). /metrics is unauthenticated —
# restrict it at the network layer when the server is publicly exposed.
KUKATKO_LOG_LEVEL=info
KUKATKO_METRICS_ENABLED=true
