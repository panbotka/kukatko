# Kukátko sample environment file (Debian/Ubuntu .deb install)
#
# This file is a dpkg conffile (nfpms type: config|noreplace). Operator edits
# are preserved across upgrades. After upgrading kukatko, diff this file against
# /etc/kukatko/kukatko.env.dpkg-dist to pick up any newly added options.
#
# Every key in config.yaml may be overridden by an environment variable using
# the KUKATKO_ prefix with dots replaced by underscores. The env value always
# wins over the (optional) YAML config file. The authoritative list of keys and
# their defaults lives in config.example.yaml in the project repository.
#
#   database.url -> KUKATKO_DATABASE_URL
#   web.port     -> KUKATKO_WEB_PORT
# Exception: the mapy.com key is read from the unprefixed MAPY_API_KEY.

# ─── Database (REQUIRED) ─────────────────────────────────────────────
# PostgreSQL 17 with the pgvector (`vector`/`halfvec`) and `unaccent`
# extensions. The DSN is the only mandatory setting.
# KUKATKO_DATABASE_URL=postgres://kukatko:CHANGEME@localhost:5432/kukatko?sslmode=disable
# KUKATKO_DATABASE_MAX_OPEN_CONNS=25
# KUKATKO_DATABASE_MAX_IDLE_CONNS=5

# ─── Bootstrap admin (recommended on first install) ──────────────────
# Auto-creates the first admin account on a fresh database. No-op once any
# user exists. If unset on a fresh install the server logs a warning and
# starts anyway; create the first user manually afterwards.
# KUKATKO_AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
# KUKATKO_AUTH_BOOTSTRAP_ADMIN_PASSWORD=change-me

# ─── Storage paths ───────────────────────────────────────────────────
# The deb postinstall creates both dirs under /var/lib/kukatko owned by the
# kukatko service user.
KUKATKO_STORAGE_ORIGINALS_PATH=/var/lib/kukatko/originals
KUKATKO_STORAGE_CACHE_PATH=/var/lib/kukatko/cache

# ─── Web server ──────────────────────────────────────────────────────
KUKATKO_WEB_HOST=0.0.0.0
KUKATKO_WEB_PORT=8080
# Secret used to sign session cookies. STRONGLY recommended in production —
# the server logs a warning at startup if it is unset.
# KUKATKO_WEB_SESSION_SECRET=change-me-to-a-long-random-string
# Enable behind a TLS-terminating reverse proxy (Secure cookies).
# KUKATKO_WEB_SECURE_COOKIES=true
# Comma-separated CORS allow-list:
# KUKATKO_WEB_ALLOWED_ORIGINS=https://photos.example.com

# ─── Embeddings service (runs on the box; may be offline) ────────────
# KUKATKO_EMBEDDING_URL=http://localhost:8000
# KUKATKO_EMBEDDING_IMAGE_DIM=768
# KUKATKO_EMBEDDING_FACE_DIM=512

# ─── Maps ────────────────────────────────────────────────────────────
# mapy.com REST key, kept server-side and proxied. Read from MAPY_API_KEY.
# MAPY_API_KEY=

# ─── S3 backup (optional) ────────────────────────────────────────────
# KUKATKO_BACKUP_S3_ENDPOINT=
# KUKATKO_BACKUP_S3_REGION=
# KUKATKO_BACKUP_S3_BUCKET=
# KUKATKO_BACKUP_S3_ACCESS_KEY=
# KUKATKO_BACKUP_S3_SECRET_KEY=
# KUKATKO_BACKUP_SCHEDULE=
